        function recalculateCostMatrix() {
            let subtotal = 0;
            let coMatch = 0;
            
            document.querySelectorAll('.checklist-checkbox').forEach(box => {
                if(box.checked) {
                    subtotal += parseFloat(box.value);
                    coMatch += parseFloat(box.getAttribute('data-tax'));
                }
            });

            let total = subtotal + coMatch;

            document.getElementById('valInvoiceSub').innerText = `$${subtotal.toLocaleString('en-US', {minimumFractionDigits: 2})} CAD`;
            document.getElementById('valInvoiceTax').innerText = `$${coMatch.toLocaleString('en-US', {minimumFractionDigits: 2})} CAD`;
            document.getElementById('valInvoiceTotal').innerText = `$${total.toLocaleString('en-US', {minimumFractionDigits: 2})} CAD`;
        }

        function logCognitiveEvent(origin, message) {
            const container = document.getElementById('aiLogsDashboardBlock');
            const card = document.createElement('div');
            card.className = 'ai-log-card';
            card.innerHTML = `
                <div class="ai-log-meta">
                    <span>${origin.toUpperCase()}</span>
                    <span>JUST NOW</span>
                </div>
                <div class="ai-log-text">${message}</div>
            `;
            container.insertBefore(card, container.firstChild);
        }

