        function evaluatePassSecurity(val) {
            const bar = document.getElementById('passStrengthBar');
            const placeholder = document.getElementById('passStrengthRow');
            if(val.length === 0) { placeholder.style.display = 'none'; return; }
            placeholder.style.display = 'block';
            let score = 0;
            if(val.length >= 6) score += 30;
            if(/[A-Z]/.test(val)) score += 35;
            if(/[0-9]/.test(val)) score += 35;

            bar.style.width = score + '%';
            if(score <= 30) bar.style.background = 'var(--accent-red)';
            else if(score <= 65) bar.style.background = 'var(--accent-orange)';
            else bar.style.background = 'var(--accent-green)';
        }

        function handleSecureLogin(e) {
            e.preventDefault();
            const loader = document.getElementById('hudLoader');
            loader.style.display = 'flex';

            setTimeout(() => {
                AppState.isAuthenticated = true;
                loader.style.display = 'none';
                
                const portal = document.getElementById('loginPortal');
                const app = document.getElementById('app-container');
                portal.style.opacity = '0';
                portal.style.transform = 'scale(0.98)';
                
                setTimeout(() => {
                    portal.style.display = 'none';
                    app.style.display = 'block';
                    setTimeout(() => app.style.opacity = '1', 50);
                    recalculateCostMatrix();
                }, 400);
            }, 1500);
        }

