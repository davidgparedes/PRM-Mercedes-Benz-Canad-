        function switchDomainExperience(domain) {
            if(domain === AppState.currentDomain) return;
            AppState.currentDomain = domain;

            const bClient = document.getElementById('btnExpClient');
            const bBiz = document.getElementById('btnExpBusiness');
            const cTabs = document.querySelectorAll('.dealer-tab');
            const bTabs = document.querySelectorAll('.hq-tab');
            const allPanels = document.querySelectorAll('.view-panel');

            allPanels.forEach(p => p.classList.remove('active'));

            if(domain === 'dealer') {
                bClient.classList.add('active');
                bBiz.classList.remove('active');
                bTabs.forEach(t => t.style.display = 'none');
                cTabs.forEach(t => t.style.display = 'block');
                
                document.getElementById('kpi-concesionario').classList.add('active');
                setActiveTabClass(document.getElementById('tabLnkVehState'));
            } else {
                bBiz.classList.add('active');
                bClient.classList.remove('active');
                cTabs.forEach(t => t.style.display = 'none');
                bTabs.forEach(t => t.style.display = 'block');
                
                document.getElementById('hq-network-performance').classList.add('active');
                setActiveTabClass(document.getElementById('tabLnkDealers'));
            }
        }

        function setActiveTabClass(activeEl) {
            document.querySelectorAll('.tab-link').forEach(t => t.classList.remove('active'));
            activeEl.classList.add('active');
        }

        function activateInternalTab(panelId, element) {
            document.querySelectorAll('.view-panel').forEach(p => p.classList.remove('active'));
            document.getElementById(panelId).classList.add('active');
            setActiveTabClass(element);
        }

