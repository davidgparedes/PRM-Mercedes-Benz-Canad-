<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mercedes-Benz Canada - Enterprise Partner Relationship Management (PRM)</title>
    <style>
        /* ==========================================================================
           1. CORE DESIGN SYSTEM & VARIABLES (Midnight Black & Satin Nordic Blue)
           ========================================================================== */
        :root {
            --midnight-black: #0a0c10;
            --deep-space: #11141a;
            --card-bg: #181d26;
            --card-hover: #222936;
            --nordic-blue: #00a3e0;
            --nordic-glow: rgba(0, 163, 224, 0.15);
            --nordic-gradient: linear-gradient(135deg, #005a9c 0%, #00a3e0 100%);
            --accent-red: #ff3b30;
            --accent-green: #34c759;
            --accent-orange: #ff9500;
            --text-primary: #ffffff;
            --text-secondary: #a0aec0;
            --text-muted: #4a5568;
            --border-color: #2d3748;
            --font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: var(--font-family);
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: var(--midnight-black);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--midnight-black);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--nordic-blue);
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ==========================================================================
           2. ENTERPRISE LOGIN PORTAL STYLES
           ========================================================================== */
        .login-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at center, var(--deep-space) 0%, var(--midnight-black) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            transition: opacity 0.5s ease, transform 0.5s ease;
        }

        .login-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            width: 100%;
            max-width: 450px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: var(--nordic-gradient);
        }

        .login-logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-logo svg {
            width: 60px;
            height: 60px;
            fill: var(--text-primary);
        }

        .login-title {
            font-size: 24px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .login-subtitle {
            font-size: 14px;
            color: var(--text-secondary);
            text-align: center;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
            position: relative;
        }

        .form-label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-secondary);
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .form-input {
            width: 100%;
            background: var(--deep-space);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 12px 16px;
            color: var(--text-primary);
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--nordic-blue);
            box-shadow: 0 0 0 3px var(--nordic-glow);
        }

        .password-strength {
            height: 4px;
            width: 100%;
            background: var(--deep-space);
            border-radius: 2px;
            margin-top: 6px;
            overflow: hidden;
            display: none;
        }

        .password-strength-bar {
            height: 100%;
            width: 0%;
            background: var(--accent-red);
            transition: all 0.3s ease;
        }

        .login-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            font-size: 13px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            color: var(--text-secondary);
        }

        .remember-me input {
            accent-color: var(--nordic-blue);
        }

        .forgot-password {
            color: var(--nordic-blue);
            text-decoration: none;
            transition: color 0.2s;
        }

        .forgot-password:hover {
            text-decoration: underline;
        }

        .btn-login {
            width: 100%;
            background: var(--nordic-gradient);
            color: var(--text-primary);
            border: none;
            border-radius: 8px;
            padding: 14px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .btn-login:hover {
            opacity: 0.95;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(0, 163, 224, 0.3);
        }

        .hud-loader {
            display: none;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--card-bg);
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 3px solid var(--border-color);
            border-top-color: var(--nordic-blue);
            border-radius: 50%;
            animation: spin 1s infinite linear;
            margin-bottom: 16px;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        /* ==========================================================================
           3. APPLICATION INTERFACE MASTER LAYOUT
           ========================================================================== */
        #app-container {
            display: none;
            opacity: 0;
            transition: opacity 0.6s ease;
        }

        .navbar {
            background-color: var(--deep-space);
            border-bottom: 1px solid var(--border-color);
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 700;
            font-size: 18px;
            letter-spacing: -0.5px;
        }

        .nav-brand svg {
            width: 32px;
            height: 32px;
            fill: var(--text-primary);
        }

        .nav-controls {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .experience-toggle {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 6px;
            border-radius: 30px;
            display: flex;
            gap: 4px;
        }

        .toggle-btn {
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            background: transparent;
            color: var(--text-secondary);
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .toggle-btn.active {
            background: var(--nordic-gradient);
            color: var(--text-primary);
            box-shadow: 0 2px 8px rgba(0, 163, 224, 0.3);
        }

        .lang-selector {
            display: flex;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
        }

        .lang-btn {
            background: transparent;
            border: none;
            color: var(--text-secondary);
            padding: 8px 12px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
        }

        .lang-btn.active {
            background: var(--border-color);
            color: var(--nordic-blue);
        }

        .user-profile-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 14px;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-color);
            border-radius: 20px;
        }

        .profile-avatar {
            width: 24px;
            height: 24px;
            background: var(--nordic-gradient);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
        }

        .tabs-header {
            background: var(--midnight-black);
            padding: 20px 40px 0 40px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            gap: 8px;
        }

        .tab-link {
            padding: 12px 24px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
            background: transparent;
            border: none;
            border-bottom: 3px solid transparent;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .tab-link:hover { color: var(--text-primary); background: rgba(255,255,255,0.02); }
        .tab-link.active { color: var(--nordic-blue); border-bottom-color: var(--nordic-blue); }

        .main-content {
            padding: 40px;
            max-width: 1600px;
            margin: 0 auto;
            animation: fadeIn 0.5s ease;
        }

        .view-panel { display: none; }
        .view-panel.active { display: block; }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 30px;
        }

        @media (max-width: 1200px) { .dashboard-grid { grid-template-columns: 1fr; } }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 30px;
        }

        .card-title {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-left: 3px solid var(--nordic-blue);
            padding-left: 10px;
        }

        /* ==========================================================================
           4. DEALER CONSOLE & OPERATIONS SPECIFIC STYLES
           ========================================================================== */
        .telemetry-row { margin-bottom: 24px; }
        .telemetry-meta { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 14px; }
        .telemetry-label { font-weight: 600; text-transform: uppercase; font-size: 12px; color: var(--text-secondary); }
        .telemetry-value { font-weight: 700; }
        .progress-container { height: 8px; background: var(--deep-space); border-radius: 4px; overflow: hidden; }
        .progress-bar { height: 100%; border-radius: 4px; transition: width 1s ease-in-out; }

        /* Allocation Matrix Allocation Grid Viewer */
        .visualizer-container {
            background: var(--deep-space);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--border-color);
        }

        .stage-360 {
            width: 100%;
            height: 420px;
            background: radial-gradient(circle at center, #232a36 0%, var(--midnight-black) 100%);
            border-radius: 8px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .allocation-map-display {
            max-width: 90%;
            max-height: 80%;
            object-fit: contain;
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            filter: drop-shadow(0 15px 25px rgba(0,0,0,0.6));
        }

        .allocation-map-display.loading { opacity: 0.3; transform: scale(0.98); }

        .rotation-controls {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(10, 12, 16, 0.85);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            padding: 6px;
            border-radius: 30px;
            display: flex;
            gap: 5px;
        }

        .angle-btn {
            background: transparent;
            border: none;
            color: var(--text-secondary);
            padding: 8px 18px;
            font-size: 12px;
            font-weight: 700;
            border-radius: 20px;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.2s;
        }

        .angle-btn.active { background: var(--nordic-blue); color: var(--text-primary); }

        .visualizer-overlay-hud {
            position: absolute;
            top: 20px;
            left: 20px;
            font-family: monospace;
            font-size: 12px;
            color: var(--nordic-blue);
            background: rgba(0,0,0,0.5);
            padding: 10px;
            border-radius: 6px;
            border-left: 2px solid var(--nordic-blue);
        }

        .specs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
        .spec-item { background: var(--deep-space); border: 1px solid var(--border-color); padding: 16px; border-radius: 8px; }
        .spec-label { font-size: 11px; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 6px; }
        .spec-value { font-size: 15px; font-weight: 700; }

        .privacy-banner {
            background: linear-gradient(90deg, rgba(0, 163, 224, 0.08) 0%, transparent 100%);
            border: 1px solid rgba(0, 163, 224, 0.2);
            border-radius: 8px;
            padding: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
        }

        .toggle-switch { position: relative; display: inline-block; width: 48px; height: 24px; }
        .toggle-switch input { opacity: 0; width: 0; height: 0; }
        .slider-round {
            position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0;
            background-color: var(--deep-space); border: 1px solid var(--border-color);
            transition: .3s; border-radius: 24px;
        }
        .slider-round:before {
            position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px;
            background-color: var(--text-secondary); transition: .3s; border-radius: 50%;
        }
        input:checked + .slider-round { background-color: var(--nordic-blue); }
        input:checked + .slider-round:before { transform: translateX(24px); background-color: var(--text-primary); }

        .btn-action {
            width: 100%; background: var(--nordic-gradient); color: white; border: none; padding: 14px;
            border-radius: 8px; font-weight: 700; cursor: pointer; text-transform: uppercase; font-size: 13px;
            transition: all 0.3s;
        }
        .btn-action:hover { box-shadow: 0 0 15px var(--nordic-blue); transform: translateY(-1px); }

        /* MDF Checklist & Ledgers */
        .checklist-group { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
        .checklist-item {
            display: flex; align-items: center; justify-content: space-between;
            background: var(--deep-space); padding: 14px 16px; border-radius: 8px;
            border: 1px solid var(--border-color); cursor: pointer; transition: all 0.2s;
        }
        .checklist-checkbox { accent-color: var(--nordic-blue); width: 16px; height: 16px; }
        .checklist-name { font-size: 14px; font-weight: 600; }
        .checklist-cost { font-size: 14px; font-weight: 700; color: var(--nordic-blue); }

        .estimator-box { background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 8px; padding: 20px; margin-top: 20px; }
        .estimator-row { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 14px; }
        .estimator-total { font-size: 18px; font-weight: 800; color: white; border-top: 1px solid var(--border-color); padding-top: 10px; }

        /* Tier Showcase Cards */
        .showroom-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
        .vehicle-card { background: var(--deep-space); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; transition: all 0.3s ease; }
        .vehicle-card:hover { transform: translateY(-5px); border-color: var(--nordic-blue); }
        .vehicle-img-box { height: 180px; background: #1a202c; display: flex; align-items: center; justify-content: center; padding: 10px; }
        .vehicle-img-box img { max-width: 100%; max-height: 100%; object-fit: contain; }
        .vehicle-info { padding: 20px; }
        .vehicle-tag { font-size: 10px; font-weight: 700; background: var(--nordic-blue); color: black; padding: 2px 6px; border-radius: 4px; display: inline-block; margin-bottom: 8px; }
        .vehicle-name { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
        .vehicle-price { font-size: 14px; color: var(--nordic-blue); font-weight: 600; }

        /* ==========================================================================
           5. HQ CORPORATE STRATEGY BI CONSOLE STYLES
           ========================================================================== */
        .metric-matrix { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .metric-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; display: flex; flex-direction: column; gap: 8px; }
        .metric-header { display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: var(--text-secondary); font-weight: 600; text-transform: uppercase; }
        .metric-trend { padding: 2px 6px; border-radius: 4px; font-size: 11px; font-weight: 700; }
        .metric-trend.up { background: rgba(52, 199, 89, 0.1); color: var(--accent-green); }
        .metric-trend.down { background: rgba(255, 59, 48, 0.1); color: var(--accent-red); }
        .metric-main-value { font-size: 28px; font-weight: 800; letter-spacing: -1px; }

        .table-responsive { width: 100%; overflow-x: auto; border-radius: 8px; border: 1px solid var(--border-color); background: var(--deep-space); }
        .data-table { width: 100%; border-collapse: collapse; text-align: left; font-size: 14px; }
        .data-table th { background: rgba(255,255,255,0.02); padding: 14px 16px; font-weight: 600; color: var(--text-secondary); border-bottom: 1px solid var(--border-color); font-size: 12px; text-transform: uppercase; }
        .data-table td { padding: 14px 16px; border-bottom: 1px solid rgba(255,255,255,0.02); }
        .data-table tr:hover td { background: rgba(255,255,255,0.01); }
        
        .status-pill { padding: 4px 8px; border-radius: 20px; font-size: 11px; font-weight: 700; display: inline-block; }
        .status-pill.success { background: rgba(52,199,89,0.1); color: var(--accent-green); }
        .status-pill.warning { background: rgba(255,149,0,0.1); color: var(--accent-orange); }

        .ai-log-container { display: flex; flex-direction: column; gap: 12px; max-height: 380px; overflow-y: auto; }
        .ai-log-card {
            background: var(--deep-space); border-left: 3px solid var(--nordic-blue); padding: 14px;
            border-radius: 0 8px 8px 0; font-size: 13px; border-top: 1px solid var(--border-color);
            border-right: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);
        }
        .ai-log-meta { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 11px; font-weight: 700; color: var(--text-secondary); }

        /* ==========================================================================
           6. LAUDON STRATEGIC PRM THEORETICAL CONFIGURATION FACTOR MAP
           ========================================================================== */
        .laudon-matrix-title { font-size: 14px; font-weight: 700; color: var(--text-secondary); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px; }
        .laudon-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
        .laudon-factor-card { background: var(--deep-space); border: 1px solid var(--border-color); border-radius: 8px; padding: 16px; transition: all 0.2s; }
        .laudon-factor-card:hover { border-color: var(--nordic-blue); }
        .factor-header { font-size: 11px; font-weight: 700; color: var(--nordic-blue); text-transform: uppercase; margin-bottom: 8px; }
        .factor-body { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }
    </style>
</head>
<body>

    <div class="login-overlay" id="loginPortal">
        <div class="login-card">
            <div class="hud-loader" id="hudLoader">
                <div class="spinner"></div>
                <div id="loaderText" style="font-size: 13px; font-weight: 600; color: var(--nordic-blue); font-family: monospace;">INITIALIZING PRM DATA EXCHANGE LINK...</div>
            </div>

            <div class="login-logo">
                <svg viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="2" fill="none"/>
                    <path d="M50 5 L50 50 L11 72.5 L50 50 L89 72.5 Z"/>
                </svg>
            </div>
            <h2 class="login-title" id="lblLoginTitle">Mercedes-Benz Canada</h2>
            <p class="login-subtitle" id="lblLoginSubtitle">Partner Relationship Management (PRM) Hub</p>

            <form id="frmAuthentication" onsubmit="handleSecureLogin(event)">
                <div class="form-group">
                    <label class="form-label" id="lblUserField">Franchise Partner ID / Email</label>
                    <input type="text" id="txtUsername" class="form-input" required placeholder="rodrigo.garcia@toronto-mercedes.ca">
                </div>
                <div class="form-group">
                    <label class="form-label" id="lblPassField">Secure Gate Key</label>
                    <input type="password" id="txtPassword" class="form-input" required oninput="evaluatePassSecurity(this.value)">
                    <div class="password-strength" id="passStrengthRow">
                        <div class="password-strength-bar" id="passStrengthBar"></div>
                    </div>
                </div>

                <div class="login-options">
                    <label class="remember-me">
                        <input type="checkbox" checked> <span id="lblRemember">Keep secure handshake active</span>
                    </label>
                    <a href="#" class="forgot-password" id="lblForgot">Recover Key Token</a>
                </div>

                <button type="submit" class="btn-login" id="btnSubmitAccess">ESTABLISH ENCRYPTED GATEWAY</button>

                <div class="biometric-auth" onclick="simulateBiometricPass()" style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 20px; padding: 12px; background: var(--deep-space); border: 1px dashed var(--border-color); border-radius: 8px; cursor: pointer; font-size: 13px; color: var(--text-secondary);">
